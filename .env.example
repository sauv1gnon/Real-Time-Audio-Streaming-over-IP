
# Endpoint addressing
CLIENT1_IP=127.0.0.1
CLIENT2_IP=127.0.0.1

# SIP ports
CLIENT1_SIP_PORT=5060
CLIENT2_SIP_PORT=5061

# RTP ports (RTCP uses port + 1)
CLIENT1_RTP_PORT=10000
CLIENT2_RTP_PORT=10002

# Media files
SAMPLE_WAV=assets/sample.wav
OUTPUT_WAV=received_audio.wav
OUTPUT_WAV_CALLER=received_audio_client1.wav

# Audio mode: wav or mic
AUDIO_SOURCE=wav
MIC_DURATION_S=5.0

# Bonus mode options
TWO_WAY_CALL=false
LIVE_PLAYBACK=false

# Protocol timing
RTCP_INTERVAL_S=5
SIP_TIMEOUT_S=10
